# Default provider does not require an API key.
REALTIME_PROVIDER=espn
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard

# Optional fallback provider if you later create a football-data.org token.
